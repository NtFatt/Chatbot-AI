{
  "name": "chatbot-ai-monorepo",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:api": "pnpm --filter @chatbot-ai/api dev",
    "dev:web": "pnpm --filter @chatbot-ai/web dev",
    "build": "pnpm build:shared && pnpm build:api && pnpm build:web",
    "build:shared": "pnpm --filter @chatbot-ai/shared build",
    "build:api": "pnpm --filter @chatbot-ai/api build",
    "build:web": "pnpm --filter @chatbot-ai/web build",
    "lint": "pnpm lint:shared && pnpm lint:api && pnpm lint:web",
    "lint:shared": "pnpm --filter @chatbot-ai/shared lint",
    "lint:api": "pnpm --filter @chatbot-ai/api lint",
    "lint:web": "pnpm --filter @chatbot-ai/web lint",
    "typecheck": "pnpm typecheck:shared && pnpm typecheck:api && pnpm typecheck:web",
    "typecheck:shared": "pnpm --filter @chatbot-ai/shared typecheck",
    "typecheck:api": "pnpm --filter @chatbot-ai/api typecheck",
    "typecheck:web": "pnpm --filter @chatbot-ai/web typecheck",
    "test": "pnpm test:api && pnpm test:web",
    "test:api": "pnpm --filter @chatbot-ai/api test",
    "test:web": "pnpm --filter @chatbot-ai/web test",
    "test:e2e": "node scripts/run-e2e.mjs",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@prisma/client": "^6.7.0",
    "@types/node": "^22.15.3",
    "@playwright/test": "^1.54.1",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "prisma": "^6.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
}

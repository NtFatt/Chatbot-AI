NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://chatbot_ai:chatbot_ai@localhost:5432/chatbot_ai?schema=public"
CLIENT_ORIGIN="http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30

GEMINI_API_KEY="replace-with-your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_ENABLED=true
GEMINI_TIMEOUT_MS=25000

OPENAI_API_KEY="replace-with-your-openai-api-key"
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_ENABLED=true
OPENAI_TIMEOUT_MS=25000

AI_PRIMARY_PROVIDER=OPENAI
AI_FALLBACK_PROVIDER=GEMINI
AI_MAX_CONTEXT_MESSAGES=10
AI_MAX_PROMPT_CHARS=12000
AI_REQUEST_RETRY_COUNT=1
AI_PROVIDER_FAILURE_THRESHOLD=3
AI_PROVIDER_COOLDOWN_MS=90000
AI_LOCAL_FALLBACK_ENABLED=true
AI_STARTUP_STRICT=false
L3_ALLOW_EXTERNAL_FALLBACK=false
L3_INTERNAL_MODEL_NAME="internal-l3-tutor-v1"
LOG_LEVEL=info

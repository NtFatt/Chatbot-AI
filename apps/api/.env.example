NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://chatbot_ai:chatbot_ai@localhost:5432/chatbot_ai?schema=public"
CLIENT_ORIGIN="http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_ENABLED=true
GEMINI_TIMEOUT_MS=25000
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_ENABLED=true
OPENAI_TIMEOUT_MS=25000
AI_MAX_CONTEXT_MESSAGES=10
AI_MAX_PROMPT_CHARS=12000
AI_REQUEST_RETRY_COUNT=1
LOG_LEVEL=info

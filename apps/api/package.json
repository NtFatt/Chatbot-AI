    "openai": "^4.104.0",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/supertest": "^6.0.3",

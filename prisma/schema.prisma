generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PreferredLanguage {
  vi
  en
  bilingual
}

enum ProviderKey {
  GEMINI
  OPENAI
  internal_l3_tutor
  local_lora
}

enum MaterialLevel {
  beginner
  intermediate
  advanced
}

enum MaterialType {
  pdf
  video
  slide
  article
  textbook
  exercise
}

enum SenderType {
  user
  assistant
  system
}

enum MessageStatus {
  sending
  streaming
  sent
  failed
  needs_sync
}

enum AIFinishReason {
  stop
  length
  error
  unknown
}

enum ArtifactType {
  summary
  flashcard_set
  quiz_set
  note
}

enum ReviewSelfAssessment {
  again
  hard
  good
  easy
}

enum TrainingDatasetStatus {
  draft
  active
  archived
}

enum TrainingExampleSourceType {
  chat_message
  artifact_refinement
  manual
}

enum TrainingExampleStatus {
  draft
  approved
  rejected
}

enum EvalCategory {
  explain_concept
  socratic_hint
  grade_answer
  generate_quiz
  summarize_lesson
  source_grounded_answer
  fallback_transparency
}

enum ModelVersionProvider {
  internal_l3_tutor
  gemini
  openai
  fine_tuned_openai
  local_ollama
  local_lora
}

enum ModelVersionStatus {
  draft
  training
  ready
  failed
  archived
}

enum TrainingJobStatus {
  draft
  queued
  running
  succeeded
  failed
}

model User {
  id                String            @id @default(uuid())
  displayName       String
  preferredLanguage PreferredLanguage @default(bilingual)
  lastSeenAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  authSessions      AuthSession[]
  chatSessions      ChatSession[]
  aiUsageLogs       AiUsageLog[]
  studyArtifacts    StudyArtifact[]
  reviewHistory     ReviewHistory[]

  @@map("users")
}

model AuthSession {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  lastUsedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model AiProviderConfig {
  provider   ProviderKey @id
  enabled    Boolean     @default(true)
  isPrimary  Boolean     @default(false)
  model      String
  timeoutMs  Int         @default(25000)
  maxRetries Int         @default(1)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@map("ai_provider_configs")
}

model ChatSession {
  id                 String                  @id @default(uuid())
  userId             String
  title              String
  providerPreference ProviderKey             @default(GEMINI)
  aiRuntimeMode      String                  @default("external_api")
  contextSummary     String?
  isPinned           Boolean                 @default(false)
  pinnedAt           DateTime?
  isArchived         Boolean                 @default(false)
  archivedAt         DateTime?
  lastReadAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           Message[]
  recommendations    RecommendationHistory[]
  aiUsageLogs        AiUsageLog[]
  studyArtifacts     StudyArtifact[]

  @@index([userId, isPinned(sort: Desc), updatedAt(sort: Desc)])
  @@index([userId, isArchived, updatedAt(sort: Desc)])
  @@index([userId, lastReadAt(sort: Desc)])
  @@map("chat_sessions")
}

model Message {
  id                    String          @id @default(uuid())
  sessionId             String
  clientMessageId       String          @unique
  parentClientMessageId String?
  senderType            SenderType
  content               String
  status                MessageStatus   @default(sent)
  provider              ProviderKey?
  model                 String?
  providerRequestId     String?
  responseFinishReason  AIFinishReason?
  latencyMs             Int?
  inputTokens           Int?
  outputTokens          Int?
  totalTokens           Int?
  confidenceScore       Float?
  subjectLabel          String?
  topicLabel            String?
  levelLabel            MaterialLevel?
  retrievalSnapshot     Json?
  fallbackUsed          Boolean         @default(false)
  errorCode             String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  session               ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  aiUsageLogs           AiUsageLog[]
  studyArtifacts        StudyArtifact[]

  @@index([sessionId, createdAt])
  @@index([sessionId, updatedAt])
  @@index([sessionId, parentClientMessageId])
  @@map("messages")
}

model Subject {
  id          String          @id @default(uuid())
  slug        String          @unique
  nameVi      String
  nameEn      String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  topics      Topic[]
  materials   StudyMaterial[]

  @@map("subjects")
}

model Topic {
  id          String          @id @default(uuid())
  subjectId   String
  slug        String
  nameVi      String
  nameEn      String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  subject     Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  materials   StudyMaterial[]

  @@unique([subjectId, slug])
  @@map("topics")
}

model StudyMaterial {
  id                    String                  @id @default(uuid())
  slug                  String                  @unique
  subjectId             String
  topicId               String?
  title                 String
  description           String
  url                   String
  type                  MaterialType
  level                 MaterialLevel
  language              String
  source                String
  tags                  String[]
  isFeatured            Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  subject               Subject                 @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  topic                 Topic?                  @relation(fields: [topicId], references: [id], onDelete: SetNull)
  recommendationHistory RecommendationHistory[]

  @@index([subjectId, topicId, level, type])
  @@index([tags], type: Gin)
  @@map("study_materials")
}

model RecommendationHistory {
  id         String        @id @default(uuid())
  sessionId  String
  materialId String
  score      Float
  reason     String[]
  createdAt  DateTime      @default(now())
  session    ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  material   StudyMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("recommendation_history")
}

model AiUsageLog {
  id            String      @id @default(uuid())
  userId        String
  sessionId     String
  messageId     String?
  provider      ProviderKey
  model         String
  inputTokens   Int?
  outputTokens  Int?
  totalTokens   Int?
  latencyMs     Int
  success       Boolean     @default(true)
  fallbackUsed  Boolean     @default(false)
  estimatedCost Decimal?    @db.Decimal(12, 6)
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message       Message?    @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_usage_logs")
}

model ProviderIncident {
  id           String      @id @default(uuid())
  provider     ProviderKey
  model        String
  errorCode    String
  errorMessage String
  retryable    Boolean     @default(false)
  requestId    String?
  createdAt    DateTime    @default(now())

  @@index([provider, createdAt])
  @@index([errorCode, createdAt])
  @@map("provider_incidents")
}

model StudyArtifact {
  id           String       @id @default(uuid())
  userId       String
  sessionId    String?
  messageId    String?
  type         ArtifactType
  title        String
  content      Json
  isFavorited  Boolean      @default(false)
  qualityScore Float?
  shareToken   String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session       ChatSession?    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message       Message?        @relation(fields: [messageId], references: [id], onDelete: SetNull)
  reviewHistory ReviewHistory[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isFavorited, createdAt(sort: Desc)])
  @@index([userId, type])
  @@index([sessionId])
  @@index([messageId])
  @@map("study_artifacts")
}

model ReviewHistory {
  id             String               @id @default(uuid())
  userId         String
  artifactId     String
  itemIndex      Int
  selfAssessment ReviewSelfAssessment
  reviewedAt     DateTime             @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifact StudyArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([userId, reviewedAt])
  @@index([artifactId])
  @@map("review_history")
}

model TrainingDataset {
  id          String                @id @default(uuid())
  name        String
  description String?
  status      TrainingDatasetStatus @default(draft)
  version     Int                   @default(1)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  examples     TrainingExample[]
  trainingJobs TrainingJob[]

  @@index([status, updatedAt(sort: Desc)])
  @@map("training_datasets")
}

model TrainingExample {
  id            String                    @id @default(uuid())
  datasetId     String
  sourceType    TrainingExampleSourceType
  sourceId      String?
  subject       String?
  topic         String?
  learningMode  String?
  userLevel     String?
  inputMessages Json
  idealResponse String
  qualityScore  Int                       @default(3)
  status        TrainingExampleStatus     @default(draft)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  dataset TrainingDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId, status, updatedAt(sort: Desc)])
  @@index([sourceType, sourceId])
  @@map("training_examples")
}

model EvalCase {
  id            String       @id @default(uuid())
  name          String
  description   String?
  category      EvalCategory
  inputMessages Json
  idealResponse String?
  scoringNotes  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  results EvalRunResult[]

  @@index([category, updatedAt(sort: Desc)])
  @@map("eval_cases")
}

model EvalRun {
  id             String      @id @default(uuid())
  provider       ProviderKey
  model          String
  modelVersionId String?
  averageScore   Float?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  modelVersion ModelVersion?   @relation(fields: [modelVersionId], references: [id], onDelete: SetNull)
  results      EvalRunResult[]

  @@index([provider, createdAt(sort: Desc)])
  @@index([modelVersionId])
  @@map("eval_runs")
}

model EvalRunResult {
  id         String   @id @default(uuid())
  runId      String
  evalCaseId String
  output     String
  score      Float
  notes      String?
  createdAt  DateTime @default(now())

  run      EvalRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  evalCase EvalCase @relation(fields: [evalCaseId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([evalCaseId])
  @@map("eval_run_results")
}

model ModelVersion {
  id             String               @id @default(uuid())
  name           String
  provider       ModelVersionProvider
  baseModel      String
  fineTunedModel String?
  status         ModelVersionStatus   @default(draft)
  isActive       Boolean              @default(false)
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  evalRuns     EvalRun[]
  trainingJobs TrainingJob[]

  @@index([provider, isActive])
  @@index([status, updatedAt(sort: Desc)])
  @@map("model_versions")
}

model TrainingJob {
  id             String               @id @default(uuid())
  datasetId      String
  provider       ModelVersionProvider
  baseModel      String
  status         TrainingJobStatus    @default(draft)
  externalJobId  String?
  modelVersionId String?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  dataset      TrainingDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  modelVersion ModelVersion?   @relation(fields: [modelVersionId], references: [id], onDelete: SetNull)

  @@index([datasetId, createdAt(sort: Desc)])
  @@index([provider, status, createdAt(sort: Desc)])
  @@index([modelVersionId])
  @@map("training_jobs")
}
